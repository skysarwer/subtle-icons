{
	"name": "subtle-icons",
	"version": "0.1.0",
	"description": "Custom Blocks.",
	"author": "Evan Buckiewicz",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip --webpack-copy-php && node -e \"const z=new(require('adm-zip'))('./subtle-icons.zip');z.deleteFile('subtle-icons/README.md');z.writeZip('./subtle-icons.zip');\"",
		"start": "wp-scripts start --webpack-copy-php"
	},
	"files": [
		"build",
		"inc",
		"subtle-icons.php"
	],
	"devDependencies": {
		"@wordpress/icons": "^11.5.0",
		"@wordpress/scripts": "^31.2.0"
	},
	"dependencies": {
		"@iconify/react": "^6.0.2",
		"@tanstack/react-virtual": "^3.13.24",
		"ajv": "^8.20.0",
		"dompurify": "^3.3.1"
	},
	"overrides": {
		"react": "^18.0.0",
		"react-dom": "^18.0.0"
	}
}
