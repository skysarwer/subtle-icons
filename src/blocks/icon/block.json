{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sbtl/icon",
	"version": "0.1.0",
	"title": "Icon",
	"category": "sbtl",
	"icon": "art",
	"description": "Choose and display an icon.",
	"supports": {
		"html": false,
		"color": {
			"background": true,
			"text": true
		},
        "spacing": {
            "margin": true,
            "padding": true
        },
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
        "align": ["center", "left", "right"]
	},
	"styles": [
		{
			"name": "default",
			"label": "Default",
			"isDefault": true
		},
		{
			"name": "rounded",
			"label": "Rounded"
		}
	],
	"textdomain": "sbtl",
	"attributes": {
		"iconMarkup": {
			"type": "string",
			"default": ""
		},
		"iconSlug": {
			"type": "string",
			"default": ""
		},
		"size": {
			"type": "string"
		},
		"stroke": {
			"type": "number"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
