<?xml version="1.0"?>
<ruleset name="Subtle Blocks Coding Standards">
  
  <!-- Configs -->
  <config name="minimum_supported_wp_version" value="4.7" />

  <!-- Exclude directories -->
  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/node_modules/*</exclude-pattern>
  <exclude-pattern>*/build/*</exclude-pattern>
  <exclude-pattern>*/tests/*</exclude-pattern>
  <exclude-pattern>*/ref/*</exclude-pattern>
  <exclude-pattern>*/scripts/*</exclude-pattern>
  <exclude-pattern>*/dependencies/*</exclude-pattern>
  
  <!-- Exclude JavaScript files (handled by Prettier) -->
  <exclude-pattern>*.js</exclude-pattern>
  <exclude-pattern>*.jsx</exclude-pattern>
  <exclude-pattern>*.ts</exclude-pattern>
  <exclude-pattern>*.tsx</exclude-pattern>

  <!-- Rules -->
  <rule ref="WordPress">
    <exclude name="WordPress.NamingConventions.PrefixAllGlobals"/>
    <exclude name="WordPress.WP.I18n"/>
    <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
  </rule>

</ruleset>